# Universal Agent OS - UiPath Labs / Automation Cloud

# true = offline demo mode
# false = strict real mode, no mock fallback
UIPATH_MOCK_MODE=true

# Required only for strict real mode
UIPATH_ORGANIZATION_NAME=
UIPATH_TENANT_NAME=DefaultTenant
UIPATH_OU_ID=
UIPATH_ACCESS_TOKEN=
UIPATH_CLIENT_ID=
UIPATH_CLIENT_SECRET=
UIPATH_RELEASE_KEY=
UIPATH_TIMEOUT_SECONDS=30

# Optional full endpoint overrides if Labs URL structure differs.
# DATA_SERVICE_API_URL must end at /dataservice_/api/EntityService.
UIPATH_ORCHESTRATOR_ODATA_URL=
UIPATH_DATA_SERVICE_API_URL=
UIPATH_ACTION_CENTER_ODATA_URL=
